        if LoadTitle then LoadTitle.Position = UDim2.new(0, offX, 0.35, offY) end
        if Red then Red.Position = UDim2.new(0, offX + (2 * progress), 0.35, offY - 2) end
        if Blue then Blue.Position = UDim2.new(0, offX - (2 * progress), 0.35, offY + 2) end

        if Sub then
            if percent < 25 then Sub.Text = "BYPASSING SECURITY..."
            elseif percent < 50 then Sub.Text = "INJECTING MODULES..."
            elseif percent < 75 then Sub.Text = "STABILIZING ENGINE..."
            else Sub.Text = "FINALIZING..." end
        end

        if Bar then
            TweenService:Create(Bar, TweenInfo.new(0.25, Enum.EasingStyle.Linear), {Size = UDim2.new(progress, 0, 1, 0)}):Play()
        end

        if progress >= 1 then break end
        task.wait(0.08)
    end
end)

