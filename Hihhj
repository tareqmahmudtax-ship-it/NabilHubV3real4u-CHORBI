--// FUNCTION CHECKER
local function getFunc(name)
    return rawget(getgenv(), name)
        or rawget(_G, name)
        or rawget(shared, name)
end

local function checkFunction(name)
    local f = getFunc(name)
    if typeof(f) ~= "function" then return false end

    local ok = pcall(function()
        if name == "getgenv" then
            f()
        end
    end)
    return ok
end

