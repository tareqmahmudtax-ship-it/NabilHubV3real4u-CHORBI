local FPS_MAX_LIMIT = 240  
local FPS_LOW_LIMIT = 3  
local LOW_FPS_TIME_ALLOWED = 5
local SAMPLE_TIME = 1  
local HIGH_VIOLATION_LIMIT = 3  
  
local frameCount = 0  
local lastTime = tick()  
local highViolations = 0  
local lowFpsTimer = 0  
  
RunService.RenderStepped:Connect(function()  
    frameCount += 1  
end)  
  
task.spawn(function()  
    while task.wait(SAMPLE_TIME) do  
        local currentTime = tick()  
        local delta = currentTime - lastTime  
        if delta > 0 then  
            local fps = math.floor(frameCount / delta)  
            frameCount = 0  
            lastTime = currentTime  
  
            if fps <= FPS_LOW_LIMIT then  
                lowFpsTimer += SAMPLE_TIME  
                if lowFpsTimer >= LOW_FPS_TIME_ALLOWED then  
                    if lp then  
                        lp:Kick("\n[NabilHub Security]\nConnection/Engine Stall Detected.\nFPS was below " .. FPS_LOW_LIMIT .. " for " .. LOW_FPS_TIME_ALLOWED .. "s.")  
                    end  
                    return  
                end  
            else  
                lowFpsTimer = 0  
            end  
  
            local checkFps = (fps > 1000) and 1000 or fps  
            if checkFps > FPS_MAX_LIMIT then  
                highViolations += 1  
                if highViolations >= HIGH_VIOLATION_LIMIT then  
                    if lp then  
                        lp:Kick("\n[NabilHub Security]\nIllegal FPS Detected: " .. fps .. "\nMax Allowed: " .. FPS_MAX_LIMIT)  
                    end  
                    return  
                end  
            else  
                highViolations = math.max(highViolations - 1, 0)  
            end  
        end  
    end  
end)  

