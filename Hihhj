local function ExtractAudioId(text)
    local id = tostring(text):match("%d+")
    return id
end

local function StopAudio()
    pcall(function()
        CustomAudio:Stop()
        CustomAudio.Playing = false
    end)

    ToggleAudio.Text = "AUDIO: OFF"
    ToggleAudio.BackgroundColor3 = Color3.fromRGB(40,20,20)

    OmniNotify.Show(
        "AUDIO SYSTEM",
        "Audio Disabled",
        2,
        "warning"
    )
end

local function PlayAudio(id)
    if not id then
        OmniNotify.Show(
            "AUDIO ERROR",
            "Invalid Audio ID",
            3,
            "error"
        )
        return
    end

    pcall(function()
        CustomAudio:Stop()

        CustomAudio.SoundId = "rbxassetid://" .. id
        CustomAudio.Volume = 2
        CustomAudio.Looped = true

        CustomAudio.Loaded:Wait()

        CustomAudio:Play()
    end)

    ToggleAudio.Text = "AUDIO: ON"
    ToggleAudio.BackgroundColor3 = Color3.fromRGB(20,60,40)

    OmniNotify.Show(
        "AUDIO SYSTEM",
        "Now Playing: " .. id,
        3,
        "success"
    )
end

