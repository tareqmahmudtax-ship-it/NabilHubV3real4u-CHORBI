local function AddToggle(name, defaultState, onEnable, onDisable)
    local state = defaultState or false
    local btn = Instance.new("TextButton", SettingsPage)
    btn.Size = UDim2.new(1, 0, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(30,30,35)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    Instance.new("UICorner", btn)

    local function Update()
        btn.Text = name .. ": " .. (state and "ON" or "OFF")
        btn.TextColor3 = state and Color3.fromRGB(0,255,127) or Color3.fromRGB(200,200,200)
        btn.BackgroundColor3 = state and Color3.fromRGB(20,40,30) or Color3.fromRGB(30,30,35)
    end

    local function Apply()
        if state then if onEnable then onEnable() end else if onDisable then onDisable() end end
    end

    btn.MouseButton1Click:Connect(function()
        state = not state
        Update()
        Apply()
    end)

    Update()
    Apply()
end

