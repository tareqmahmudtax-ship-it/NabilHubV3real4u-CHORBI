local function CreateNotification(data, index)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 260, 0, 70)
    frame.Position = UDim2.new(1, 20, 0.15, (index - 1) * 80)
    frame.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    frame.BorderSizePixel = 0
    frame.Parent = NotifyGui
    frame.ClipsDescendants = true

    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)

    local stroke = Instance.new("UIStroke", frame)
    stroke.Thickness = 1.5
    stroke.Transparency = 0.3

    local icon = Instance.new("TextLabel", frame)
    icon.Size = UDim2.new(0, 26, 0, 26)
    icon.Position = UDim2.new(0, 10, 0, 22)
    icon.BackgroundTransparency = 1
    icon.Font = Enum.Font.GothamBold
    icon.TextSize = 20
    icon.Text = Icons[data.type or "info"]

    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(1, -50, 0.4, 0)
    title.Position = UDim2.new(0, 44, 0, 5)
    title.BackgroundTransparency = 1
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Font = Enum.Font.GothamBold
    title.TextSize = 14
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.Text = data.title or "OMNIPOTENCE"

    local msg = Instance.new("TextLabel", frame)
    msg.Size = UDim2.new(1, -50, 0.6, 0)
    msg.Position = UDim2.new(0, 44, 0.4, 0)
    msg.BackgroundTransparency = 1
    msg.TextXAlignment = Enum.TextXAlignment.Left
    msg.Font = Enum.Font.Gotham
    msg.TextSize = 12
    msg.TextColor3 = Color3.fromRGB(200, 200, 200)
    msg.Text = data.text or ""

    local t = data.type or "info"
    if t == "success" then
        stroke.Color = Color3.fromRGB(0, 255, 127)
        icon.TextColor3 = Color3.fromRGB(0, 255, 127)
    elseif t == "error" then
        stroke.Color = Color3.fromRGB(255, 60, 60)
        icon.TextColor3 = Color3.fromRGB(255, 60, 60)
    elseif t == "warning" then
        stroke.Color = Color3.fromRGB(255, 200, 0)
        icon.TextColor3 = Color3.fromRGB(255, 200, 0)
    else
        stroke.Color = Color3.fromRGB(0, 150, 255)
        icon.TextColor3 = Color3.fromRGB(0, 150, 255)
    end

    local ProgressBG = Instance.new("Frame", frame)
    ProgressBG.Size = UDim2.new(1, -20, 0, 3)
    ProgressBG.Position = UDim2.new(0, 10, 1, -6)
    ProgressBG.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    ProgressBG.BorderSizePixel = 0
    Instance.new("UICorner", ProgressBG).CornerRadius = UDim.new(1, 0)

    local Progress = Instance.new("Frame", ProgressBG)
    Progress.Size = UDim2.new(1, 0, 1, 0)
    Progress.BackgroundColor3 = stroke.Color
    Progress.BorderSizePixel = 0
    Instance.new("UICorner", Progress).CornerRadius = UDim.new(1, 0)

    ProxyTween:Create(Progress, TweenInfo.new(data.duration, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 1, 0)}):Play()

    local dragging = false
    local startX = 0
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            startX = input.Position.X
        end
    end)

    frame.InputEnded:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
            dragging = false
            if input.Position.X - startX > 60 then
                OmniNotify.Remove(frame)
            end
        end
    end)

    return frame
end

function OmniNotify.Show(title, text, duration, ntype)
    table.insert(Queue, {title = title, text = text, duration = duration or 3, type = ntype or "info"})
    if #Active == 0 then OmniNotify.Process() end
end

function OmniNotify.Process()
    while #Queue > 0 do
        local data = table.remove(Queue, 1)
        local index = #Active + 1
        local ui = CreateNotification(data, index)
        table.insert(Active, ui)

        ProxyTween:Create(ui, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {Position = UDim2.new(1, -280, 0.15, (index - 1) * 80)}):Play()

        task.spawn(function()
            task.wait(data.duration)
            if ui and ui.Parent then OmniNotify.Remove(ui) end
        end)
    end
end

function OmniNotify.Remove(ui)
    for i, v in ipairs(Active) do
        if v == ui then
            table.remove(Active, i)
            break
        end
    end
    ProxyTween:Create(ui, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {Position = UDim2.new(1, 300, ui.Position.Y.Scale, ui.Position.Y.Offset), BackgroundTransparency = 1}):Play()
    task.wait(0.25)
    if ui then ui:Destroy() end
    for i, v in ipairs(Active) do
        ProxyTween:Create(v, TweenInfo.new(0.2), {Position = UDim2.new(1, -280, 0.15, (i - 1) * 80)}):Play()
    end
end

local function MakeDraggable(gui)
    local dragging, dragInput, dragStart, startPos
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = gui.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    gui.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

