local function ExtractAudioId(text)
    return tostring(text):match("%d+")
end

local function StopAudio()
    pcall(function() CustomAudio:Stop() end)
    ToggleAudio.Text = "AUDIO: OFF"
    ToggleAudio.BackgroundColor3 = Color3.fromRGB(40,20,20)
    OmniNotify.Show("AUDIO SYSTEM", "Audio Disabled", 2, "warning")
end

local function PlayAudio(id)
    if not id then return end
    pcall(function()
        CustomAudio:Stop()
        CustomAudio.SoundId = "rbxassetid://" .. id
        if not CustomAudio.IsLoaded then CustomAudio.Loaded:Wait() end
        CustomAudio:Play()
    end)
    ToggleAudio.Text = "AUDIO: ON"
    ToggleAudio.BackgroundColor3 = Color3.fromRGB(20,60,40)
    OmniNotify.Show("AUDIO SYSTEM", "Now Playing: " .. id, 3, "success")
end

